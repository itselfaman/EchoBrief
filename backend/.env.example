# ─────────────────────────────────────────────────────────
#  EchoBrief Backend — Environment Configuration
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────
APP_NAME="EchoBrief"
APP_VERSION="1.0.0"
DEBUG=false
ENVIRONMENT=development

# ── Database (Supabase PostgreSQL) ───────────────────────
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql+asyncpg://postgres.xxxxxxxxxxxx:YOUR_DB_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# ── Supabase ─────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...
# JWT Secret — found in Supabase Dashboard > Settings > API > JWT Secret
SUPABASE_JWT_SECRET=your-super-secret-jwt-token-from-supabase
SUPABASE_STORAGE_BUCKET=media-files

# ── Redis ────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=  # Leave blank if no auth on local Redis

# ── OpenAI (Whisper Transcription) ───────────────────────
OPENAI_API_KEY=sk-proj-...
WHISPER_MODEL=whisper-1

# ── Google Gemini (Summarization — Free Tier) ────────────
# Get free API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-1.5-flash

# ── File Upload Limits ───────────────────────────────────
MAX_FILE_SIZE_BYTES=10737418240   # 10 GB in bytes

# ── CORS ─────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_UPLOADS_PER_MINUTE=10

# ── Worker Config ────────────────────────────────────────
DRAMATIQ_MAX_RETRIES=3
TEMP_MEDIA_DIR=C:/temp/echobrief
